{
    "agent": {
        "metrics_collection_interval": 60,
        "run_as_user": "cwagent"
    },
    "metrics": {
        "metrics_collected": {
            "mem": {
                "measurement": [
                    "mem_used_percent"
                ]
            },
            "disk": {
                "measurement": [
                    "disk_used_percent"
                ],
                "resources": [
                    "/"
                ]
            }
        }
    },
    "logs": {
        "logs_collected": {
            "files": {
                "collect_list": [
                    {
                        "file_path": "/var/log/syslog",
                        "log_group_name": "IronFortress-System-Logs",
                        "log_stream_name": "{instance_id}"
                    },
                    {
                        "file_path": "/home/ubuntu/app.log",
                        "log_group_name": "IronFortress-App-Logs",
                        "log_stream_name": "backend-stream"
                    }
                ]
            }
        }
    }
}
