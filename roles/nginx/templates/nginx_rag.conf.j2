{% for app in nginx_apps %}
# 1. HTTP (80) -> HTTPS (443) 리다이렉트 블록
server {
    listen 80;
    listen [::]:80;
    server_name {{ app.server_name }};
    return 301 https://$host$request_uri;
}

# 2. HTTPS (443) 실제 서비스 블록
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ app.server_name }};

    # SSL 설정 (Certbot이 생성해준 경로 참조)
    ssl_certificate /etc/letsencrypt/live/{{ app.server_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ app.server_name }}/privkey.pem;

    # SSL 보안 설정
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_pass http://127.0.0.1:{{ app.internal_port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;

        # WebSocket 및 스트리밍 지원 
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # 타임아웃 설정
        proxy_read_timeout 300s;
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
    }

    access_log /var/log/nginx/{{ app.name }}_access.log;
    error_log /var/log/nginx/{{ app.name }}_error.log;
}
{% endfor %}
